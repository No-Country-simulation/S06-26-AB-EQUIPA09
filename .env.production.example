NODE_ENV=production

# Public URL where users open the frontend.
APP_URL=https://sqlens.example.com
WEB_PORT=80

# Backend
PORT=3001
JWT_SECRET=replace-with-at-least-32-random-characters
SIGNED_URL_SECRET=replace-with-another-random-secret
ENCRYPTION_KEY=replace-with-64-hex-characters
CORS_ORIGINS=https://sqlens.example.com
CORS_CREDENTIALS=true
COOKIE_DOMAIN=
TRUSTED_PROXY=true
LOG_LEVEL=info
LOG_PRETTY=false
STORAGE_DRIVER=local

# Database
DB_USER=sqlens
DB_PASSWORD=replace-with-a-strong-database-password
DB_DATABASE=sqlens
DB_PORT=5432
DB_SSL=false
DB_MAX_CONNECTIONS=10

# AI agent
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Initial staff seed. Run manually with:
# docker compose --env-file .env.production -f docker-compose.prod.yml exec api bun src/db/seed.ts
STAFF_SEED_EMAIL=admin@sqlens.ao
STAFF_SEED_NAME=Admin SQLens
STAFF_SEED_PASSWORD=replace-with-a-strong-staff-password
